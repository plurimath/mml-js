{
  "name": "@plurimath/mml",
  "version": "0.1.0",
  "private": false,
  "description": "JavaScript release of plurimath/mml, published as @plurimath/mml on npm. Opal-compiled with optional shared runtime from @lutaml/opal-runtime.",
  "main": "./dist/mml-no-opal.js",
  "module": "./dist/mml-no-opal.js",
  "browser": "./dist/mml.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/mml.js",
      "import": "./dist/mml-no-opal.js",
      "require": "./dist/mml-no-opal.js",
      "default": "./dist/mml-no-opal.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "test": "node scripts/test.js"
  },
  "keywords": [
    "mml",
    "mathml",
    "math",
    "opal",
    "ruby",
    "plurimath"
  ],
  "license": "BSD-2-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/plurimath/mml-js"
  },
  "homepage": "https://github.com/plurimath/mml-js#readme",
  "bugs": {
    "url": "https://github.com/plurimath/mml-js/issues"
  },
  "devDependencies": {
    "@lutaml/opal-runtime": "^1.0.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@lutaml/opal-runtime": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@lutaml/opal-runtime": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}